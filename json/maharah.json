          },
          {
            "id": 4,
            "label": "الْمُطْعِمُ بْنُ عَدِيٍّ",
            "jawaban": ["الشَّاقُّ", "الْمُنْقِذُ"]
          }
        ]
      },
      {
        "judul": "السؤال ٢",
        "instruksi": "أَكْمِلِ الْخَرِيطَةَ الْمَفَاهِيمِيَّةَ بِكِتَابَةِ كَلِمَةٍ أَوْ عِبَارَةٍ",
        "soal": [
          {
            "id": 1,
            "label": "الْمُقَاطَعَةُ=الْمَكَانُ",
            "jawaban": ["شِعْبُ أَبِي طَالِبٍ"]
          },
          {
            "id": 2,
            "label": "الْمُقَاطَعَةُ = الْمُدَّةُ",
            "jawaban": ["ثَلَاثَةُ أَعْوَامٍ"]
          },
          {
            "id": 3,
            "label": "الْمُقَاطَعَةُ = السَّبَبُ",
            "jawaban": ["انْتِشَارُ الإِسْلَامِ"]
          },
          {
            "id": 4,
            "label": "الْمُقَاطَعَةُ = النَّتِيجَةُ",
            "jawaban": ["إِنْهَاءُ الْحِصَارِ"]
          }
        ]
      },
      {
        "judul": "السؤال ٣",
        "instruksi": "أَكْمِلِ الْعِبَارَةَ بِالْفِعْلِ الْمُنَاسِبِ",
        "soal": [
          {
            "id": 1,
            "label": "قُرَيْشٌ ………… بَنِي هَاشِمٍ",
