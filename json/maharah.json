  "level2": {
    "judul": "مقاطعة قريش",
    "sections": [
      {"judul": "السؤال ١",
        "instruksi": "أَجِبْ عَنْ كُلِّ سُؤَالٍ بِجُمْلَةٍ كَامِلَةٍ",
        "soal": [
          {
            "id": 1,
            "pertanyaan": "لماذا قررت قريش المقاطعة؟"
          },
          {
            "id": 2,
            "pertanyaan": "أَيْنَ عَاشَ الْمُسْلِمُونَ خِلَالَ الْحِصَارِ؟"
          },
          {
            "id": 3,
            "pertanyaan": "كَيْفَ انْتَهَتِ الْمُقَاطَعَةُ؟"
          }
        ]
      },
      {"judul": "السؤال ٢",
        "instruksi": "حَوِّلِ الْجُمَلَ كَمَا هُوَ مَطْلُوبٌ",
        "soal": [
          {
            "id": 1,
            "pertanyaan": "حَوِّلْ إِلَى الْمَجْهُولِ: كَتَبَ زُعَمَاءُ قُرَيْشٍ الصَّحِيفَةَ"
          },
          {
            "id": 2,
            "pertanyaan": "حَوِّلْ إِلَى النَّفْيِ: صَبَرَ الْمُسْلِمُونَ عَلَى الْحِصَارِ"
          },
          {
            "id": 3,
            "pertanyaan": "حَوِّلْ إِلَى الْمُضَارِعِ: شَقَّ الْمُطْعِمُ الصَّحِيفَةَ"
          }
        ]
      },
      {"judul": "السؤال ٣",
        "instruksi": "اُكْتُبْ جُمْلَةً وَاحِدَةً تَصِفُ فِيهَا كُلَّ شَخْصٍ مِنَ الأَشْخَاصِ الآتِيَةِ بِأُسْلُوبِكَ أَنْتَ",
        "soal": [
          {
            "id": 1,
            "pertanyaan": "أَبُو طَالِبٍ"
          },
          {
            "id": 2,
            "pertanyaan": "الْمُطْعِمُ بْنُ عَدِيٍّ"
          },
          {
            "id": 3,
            "pertanyaan": "الرَّسُولُ ﷺ فِي هَذِهِ الْمَرْحَلَةِ"
          }
        ]
      }
    ]
  },

  "level3": {
    "judul": "مقاطعة قريش",
    "sections": [
      {"judul": "السؤال ١",
        "instruksi": "اُكْتُبْ مُلَخَّصًا قَصِيرًا لِحَادِثَةِ الْمُقَاطَعَةِ فِي جُمْلَتَيْنِ أَوْ ثَلَاثِ جُمَلٍ مُتَرَابِطَةٍ. يَجِبُ أَنْ تَشْمَلَ: السَّبَبَ، مَا حَدَثَ، وَالنَّتِيجَةَ.",
        "soal": [
          {
            "id": 1,
            "pertanyaan": "اكتب الإجابة هنا"
          }
        ]
      },
      {"judul": "السؤال ٢",
        "instruksi": "قَارِنْ بَيْنَ حَالِ الْمُسْلِمِينَ قَبْلَ الْمُقَاطَعَةِ وَبَعْدَهَا فِي جُمْلَتَيْنِ أَوْ ثَلَاثٍ مُسْتَخْدِمًا أَدَوَاتِ الْمُقَارَنَةِ مِثْلَ: (بَيْنَمَا، فِي حِينِ أَنَّ، عَلَى الرَّغْمِ مِنْ).",
        "soal": [
          {
            "id": 1,
            "pertanyaan": "اكتب الإجابة هنا"
          }
        ]
      },
      {"judul": "السؤال ٣",
        "instruksi": "اُكْتُبْ جُمْلَتَيْنِ أَوْ ثَلَاثًا تَشْرَحُ فِيهَا: لِمَاذَا يُعَدُّ صَبْرُ الْمُسْلِمِينَ فِي الشِّعْبِ دَلِيلًا عَلَى قُوَّةِ إِيمَانِهِمْ؟",
        "soal": [
          {
            "id": 1,
            "pertanyaan": "اكتب الإجابة هنا"
          }
        ]
      }
    ]
  },

